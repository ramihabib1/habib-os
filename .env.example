TELEGRAM_RAMI_CHAT_ID=xxx
TELEGRAM_FATHER_CHAT_ID=xxx
TELEGRAM_MAREE_CHAT_ID=xxx

# System
LOG_LEVEL=INFO
ENVIRONMENT=development
